# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values before running docker-compose.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# PostgreSQL credentials (used by both the db and backend services)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_production

# JWT signing secret – REQUIRED, minimum 32 characters, no hard-coded default.
# Generate a strong value with: openssl rand -hex 32
APP_JWT_SECRET=replace_with_a_cryptographically_random_secret_min_32_chars

# Optional: OpenAI API key for AI features (leave as-is to disable AI routes)
OPENAI_API_KEY=your_openai_api_key_here

# Public URL of the frontend (used by middleware for CORS headers in prod)
# Set to your real domain when deploying: e.g. https://app.example.com
FRONTEND_URL=http://localhost:3000

# Middleware host as seen by the frontend nginx container
# Docker Compose: middleware:4000
# Railway:        middleware.railway.internal:4000
MIDDLEWARE_HOST=middleware:4000

# CORS origins the backend will accept (comma-separated, no spaces)
# In production, set to your frontend domain only:
#   APP_CORS_ALLOWED_ORIGINS=https://app.example.com
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:4000,http://middleware:4000
